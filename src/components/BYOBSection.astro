---
import { t } from "../i18n/utils";

interface Props { locale: "en" | "fr"; }
const { locale } = Astro.props;
const i = t(locale);
---

<section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
  <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
  <div class="absolute left-0 bottom-0 h-[400px] w-[400px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
  <div class="mx-auto max-w-5xl">
    <div class="reveal grid items-center gap-12 md:grid-cols-2">
      <div>
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.byobSection.label}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.byobSection.title}</h2>
        <p class="mt-6 text-base leading-relaxed text-white/65">{i.byobSection.desc}</p>
        <div class="mt-8 space-y-3">
          {[
            { icon: "🍷", text: i.byobSection.noCorkage },
            { icon: "🍺", text: i.byobSection.beerWine },
            { icon: "🚗", text: i.byobSection.freeParking },
          ].map((item, idx) => (
            <div class={`reveal reveal-delay-${idx + 1} flex items-center gap-3`}>
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-golden/15 bg-night-800/80 text-base">{item.icon}</span>
              <span class="text-sm font-medium text-white/60">{item.text}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="relative">
        <div class="overflow-hidden rounded-3xl border border-white/[0.06]">
          <picture>
            <source srcset="/images/restaurant-dining.webp" type="image/webp" />
            <img src="/images/restaurant-dining.jpg" alt={locale === "en" ? "BYOB dining experience at Krong Thai Restaurant" : "Expérience apportez votre vin au Restaurant Krong Thai"} class="aspect-[4/3] w-full object-cover" loading="lazy" width="1200" height="800" />
          </picture>
        </div>
        <div class="absolute -bottom-4 -right-4 rounded-2xl border border-golden/20 bg-black/80 px-5 py-3 backdrop-blur-md">
          <span class="text-sm font-bold text-golden-light">🍷 {i.byobSection.noCorkage}</span>
        </div>
      </div>
    </div>
  </div>
</section>
