---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  class?: string;
}

const { href, variant = "primary", size = "md", external = false, class: className = "" } = Astro.props;

const variants = {
  primary: "bg-krong-red text-white shadow-red hover:shadow-xl hover:brightness-110 active:scale-[0.97] pulse-cta",
  secondary: "bg-gradient-to-r from-golden to-golden-light text-night-900 font-bold hover:shadow-gold hover:shadow-xl active:scale-[0.97]",
  outline: "bg-white/[0.05] text-white border border-white/15 backdrop-blur-sm hover:bg-white/10 hover:border-white/25",
  ghost: "text-white/70 hover:text-white hover:bg-white/[0.05]",
};

const sizes = {
  sm: "px-5 py-2.5 text-sm",
  md: "px-7 py-3 text-sm",
  lg: "px-9 py-4 text-base sm:px-11 sm:py-5 sm:text-lg",
};

const externalAttrs = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a
  href={href}
  class:list={[
    "inline-flex items-center justify-center rounded-full font-bold transition-all duration-300",
    variants[variant],
    sizes[size],
    className,
  ]}
  {...externalAttrs}
>
  <slot />
</a>
