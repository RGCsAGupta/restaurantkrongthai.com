---
import { business } from "../data/business";
import { type Locale, t } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
---

<section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
  <div class="divider-gold mx-auto mb-24 max-w-xs"></div>

  <div class="reveal mx-auto max-w-5xl">
    <div class="relative overflow-hidden rounded-[2rem] border border-white/[0.08]">
      <!-- Background food image -->
      <img src="/promo/images/thai-fried-rice.jpg" alt="" class="absolute inset-0 h-full w-full object-cover opacity-25" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-br from-night-950/95 via-night-900/90 to-night-950/95"></div>

      <!-- Red glow accent -->
      <div class="absolute right-0 top-0 h-[300px] w-[300px] rounded-full bg-krong-red/10 blur-[100px]"></div>

      <div class="relative grid items-center gap-10 p-8 sm:p-12 md:grid-cols-2 md:p-16">
        <!-- Left: Content -->
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-krong-red/30 bg-krong-red/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-krong-red-glow">
            <span class="h-1.5 w-1.5 rounded-full bg-krong-red animate-pulse"></span>
            {locale === "fr" ? "Plus populaire" : "Most Popular"}
          </div>
          <h2 class="mt-6 font-display text-4xl font-bold text-white sm:text-5xl">
            {i.combo.title}
          </h2>
          <p class="mt-4 text-lg text-white/40">{i.combo.includes}</p>
          <ul class="mt-8 space-y-4">
            {[
              locale === "fr" ? "Soupe au choix" : "Choice of Soup",
              locale === "fr" ? "Entrée au choix" : "Choice of Appetizer",
              locale === "fr" ? "Café ou Thé inclus" : "Coffee or Tea Included",
            ].map((item) => (
              <li class="flex items-center gap-3 text-white/60">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-golden/15 text-xs text-golden">✓</span>
                <span class="text-[15px]">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Price + CTA -->
        <div class="text-center md:text-right">
          <div class="mb-2 text-sm font-medium text-white/25 line-through">{locale === "fr" ? "15,95 $" : "$15.95"}</div>
          <div class="font-display text-7xl font-bold text-white sm:text-8xl">
            {i.combo.price}
          </div>
          <div class="mt-2 text-sm font-bold text-golden">{locale === "fr" ? "Économisez 5 $" : "Save $5"}</div>

          <a
            href={business.orderingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-10 inline-flex items-center gap-3 rounded-full bg-krong-red px-10 py-5 text-lg font-bold text-white shadow-red transition-all duration-300 hover:shadow-xl hover:brightness-110 active:scale-[0.97] pulse-cta"
          >
            {i.combo.cta}
          </a>
          <p class="mt-4 text-xs text-white/20">{locale === "fr" ? "Prêt en 15-20 min · Fraîchement préparé" : "Ready in 15-20 min · Freshly prepared"}</p>
        </div>
      </div>
    </div>
  </div>
</section>
