---
import { slugMap, reverseSlugMap } from "../i18n/utils";
import { business } from "../data/business";

interface Props {
  title: string;
  description: string;
  locale: "en" | "fr";
  canonicalPath?: string;
  alternatePath?: string;
  breadcrumbs?: Array<{ name: string; path: string }>;
  ogImage?: string;
}

const { title, description, locale, canonicalPath = "", alternatePath, breadcrumbs, ogImage } = Astro.props;
const i = t(locale);
const isHomepage = canonicalPath === "";
const base = "https://restaurantkrongthai.com";
const canonical = `${base}/${locale}/${canonicalPath}`.replace(/\/$/, "") + "/";
const alternateLang = locale === "en" ? "fr" : "en";
const hreflangLocale = locale === "en" ? "en-CA" : "fr-CA";
const hreflangAlt = locale === "en" ? "fr-CA" : "en-CA";

const altPath = alternatePath
  ? alternatePath
  : locale === "en"
    ? slugMap[canonicalPath] ?? canonicalPath
    : reverseSlugMap[canonicalPath] ?? canonicalPath;
const alternate = `${base}/${alternateLang}/${altPath}`.replace(/\/$/, "") + "/";
const ogImageUrl = ogImage ? `${base}${ogImage}` : `${base}/images/og-image.jpg`;

// Page name for breadcrumbs
const pageNames: Record<string, Record<string, string>> = {
  en: { menu: "Menu", about: "About", catering: "Catering", specials: "Specials", gallery: "Gallery", contact: "Contact", privacy: "Privacy Policy", accessibility: "Accessibility", areas: "Service Areas", thanks: "Thank You" },
  fr: { menu: "Menu", "a-propos": "À propos", traiteur: "Traiteur", speciaux: "Spéciaux", galerie: "Galerie", contact: "Contact", confidentialite: "Confidentialité", accessibilite: "Accessibilité", "zones-de-service": "Zones de service", merci: "Merci" },
};
const localSlug = locale === "en" ? canonicalPath : (slugMap[canonicalPath] ?? canonicalPath);
const pageName = pageNames[locale]?.[localSlug];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang={hreflangLocale} href={canonical} />
<link rel="alternate" hreflang={hreflangAlt} href={alternate} />
<link rel="alternate" hreflang="x-default" href={`${base}/fr/`} />
<meta name="theme-color" content="#0A0A0A" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={locale === "fr" ? "fr_CA" : "en_CA"} />
<meta property="og:site_name" content="Restaurant Krong Thai" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
{(canonicalPath === "thanks" || canonicalPath === "merci") ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow" />
)}
<meta name="geo.region" content="CA-QC" />
<meta name="geo.placename" content="Gatineau" />
<meta name="geo.position" content="45.4765;-75.7013" />
<meta name="ICBM" content="45.4765, -75.7013" />
<meta property="og:image:alt" content="Krong Thai Restaurant — Authentic Thai, Vietnamese & Cambodian Cuisine" />
<!-- Preload critical fonts to prevent layout shift -->
<link rel="preload" as="font" href="/fonts/dm-sans-latin.woff2" type="font/woff2" crossorigin />
<link rel="preload" as="font" href="/fonts/playfair-latin.woff2" type="font/woff2" crossorigin />
{!canonicalPath && (
  <link rel="preload" as="image" type="image/webp" href="/images/bangkok-soup-large.webp" />
)}
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "@id": "https://restaurantkrongthai.com/#restaurant",
  "name": "Restaurant Krong Thai",
  "image": `${base}/images/hero.jpg`,
  "url": "https://restaurantkrongthai.com",
  "foundingDate": "1999",
  "dateModified": "2026-04-04",
  "founder": {
    "@type": "Person",
    "name": "Sothea Say",
    "jobTitle": locale === "fr" ? "Fondatrice" : "Founder"
  },
  "telephone": "+18192435000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "205 Rue Bellehumeur",
    "addressLocality": "Gatineau",
    "addressRegion": "QC",
    "postalCode": "J8T 8H3",
    "addressCountry": "CA"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": business.coordinates.lat, "longitude": business.coordinates.lng },
  "servesCuisine": ["Thai", "Vietnamese", "Cambodian"],
  "priceRange": "$$",
  "acceptsReservations": "True",
  "paymentAccepted": "Cash, Credit Card, Debit Card",
  "currenciesAccepted": "CAD",
  "sameAs": [
    business.social.facebook,
    business.social.instagram,
    business.social.yelp,
    business.social.tripadvisor,
    business.delivery.ubereats,
    business.delivery.doordash,
    business.delivery.skip
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": `${base}/${locale}/menu/`,
    "name": locale === "fr" ? "Menu du restaurant" : "Restaurant Menu",
    "hasMenuSection": [
      {
        "@type": "MenuSection",
        "name": locale === "fr" ? "Les favoris" : "Fan Favourites",
        "hasMenuItem": [
          {
            "@type": "MenuItem",
            "name": locale === "fr" ? "Soupe Bangkok" : "Bangkok Soup",
            "description": locale === "fr"
              ? "Soupe signature la plus populaire — plébiscitée à 93 % par nos clients Google."
              : "Most popular signature soup — 93% customer approval on Google.",
            "offers": { "@type": "Offer", "priceCurrency": "CAD" }
          },
          {
            "@type": "MenuItem",
            "name": "Pad Thai",
            "description": locale === "fr"
              ? "Nouilles de riz sautées classiques avec votre choix de protéine — approbation de 95 %."
              : "Classic stir-fried rice noodles with your choice of protein — 95% customer approval.",
            "offers": { "@type": "Offer", "priceCurrency": "CAD" }
          },
          {
            "@type": "MenuItem",
            "name": locale === "fr" ? "Rouleaux impériaux" : "Imperial Rolls",
            "description": locale === "fr"
              ? "Rouleaux dorés croustillants servis avec sauce maison."
              : "Crispy golden rolls served with house-made dipping sauce.",
            "offers": { "@type": "Offer", "priceCurrency": "CAD" }
          },
          {
            "@type": "MenuItem",
            "name": locale === "fr" ? "Spécial du midi (Table d'hôte)" : "Lunch Special (Table d'hôte)",
            "description": locale === "fr"
              ? "Soupe + entrée + riz jasmin + café ou thé + biscuits aux amandes."
              : "Soup + appetizer + jasmine rice + coffee or tea + almond cookies.",
            "offers": { "@type": "Offer", "price": "10.00", "priceCurrency": "CAD", "priceValidUntil": "2025-12-31" }
          }
        ]
      }
    ]
  },
  "potentialAction": {
    "@type": "OrderAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": business.orderingUrl,
      "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
    },
    "deliveryMethod": ["http://purl.org/goodrelations/v1#DeliveryModePickUp"]
  },
  "areaServed": [
    { "@type": "City", "name": "Gatineau" },
    { "@type": "City", "name": "Ottawa" },
    { "@type": "AdministrativeArea", "name": "Hull" },
    { "@type": "AdministrativeArea", "name": "Aylmer" },
    { "@type": "AdministrativeArea", "name": "Outaouais" }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.2",
    "reviewCount": "220",
    "bestRating": "5",
    "worstRating": "1"
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "15:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Wednesday", "Thursday"], "opens": "11:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Friday", "Saturday"], "opens": "11:00", "closes": "22:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "15:00", "closes": "21:00" }
  ]
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Restaurant Krong Thai",
  "url": base,
  "inLanguage": [locale === "fr" ? "fr-CA" : "en-CA"],
  "publisher": { "@type": "Organization", "name": "Restaurant Krong Thai", "url": base }
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": canonical,
  "inLanguage": locale === "fr" ? "fr-CA" : "en-CA",
  "datePublished": "2024-01-01",
  "dateModified": "2026-04-04",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "[data-speakable]", "meta[name='description']"]
  }
})} />
{breadcrumbs ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, idx) => ({
      "@type": "ListItem",
      "position": idx + 1,
      "name": crumb.name,
      "item": `${base}${crumb.path}`
    }))
  })} />
) : pageName ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": locale === "fr" ? "Accueil" : "Home", "item": `${base}/${locale}/` },
      { "@type": "ListItem", "position": 2, "name": pageName, "item": canonical }
    ]
  })} />
) : null}
<!-- Clarity loaded via CookieConsent component after user consent -->
