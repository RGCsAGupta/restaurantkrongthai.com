---
import { slugMap, reverseSlugMap } from "../i18n/utils";
import { business } from "../data/business";

interface Props {
  title: string;
  description: string;
  locale: "en" | "fr";
  canonicalPath?: string;
}

const { title, description, locale, canonicalPath = "" } = Astro.props;
const base = "https://restaurantkrongthai.com";
const canonical = `${base}/${locale}/${canonicalPath}`.replace(/\/$/, "") + "/";
const alternateLang = locale === "en" ? "fr" : "en";

const altPath =
  locale === "en"
    ? slugMap[canonicalPath] ?? canonicalPath
    : reverseSlugMap[canonicalPath] ?? canonicalPath;
const alternate = `${base}/${alternateLang}/${altPath}`.replace(/\/$/, "") + "/";

// Page name for breadcrumbs
const pageNames: Record<string, Record<string, string>> = {
  en: { menu: "Menu", about: "About", catering: "Catering", specials: "Specials", gallery: "Gallery", contact: "Contact", privacy: "Privacy Policy", accessibility: "Accessibility", thanks: "Thank You" },
  fr: { menu: "Menu", "a-propos": "À propos", traiteur: "Traiteur", speciaux: "Spéciaux", galerie: "Galerie", contact: "Contact", confidentialite: "Confidentialité", accessibilite: "Accessibilité", merci: "Merci" },
};
const localSlug = locale === "en" ? canonicalPath : (slugMap[canonicalPath] ?? canonicalPath);
const pageName = pageNames[locale]?.[localSlug];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang={locale} href={canonical} />
<link rel="alternate" hreflang={alternateLang} href={alternate} />
<link rel="alternate" hreflang="x-default" href={`${base}/fr/`} />
<meta name="theme-color" content="#0A0A0A" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={`${base}/images/og-image.jpg`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={locale === "fr" ? "fr_CA" : "en_CA"} />
<meta property="og:site_name" content="Krong Thai Restaurant" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${base}/images/og-image.jpg`} />
<meta name="robots" content="index, follow" />
<meta name="geo.region" content="CA-QC" />
<meta name="geo.placename" content="Gatineau" />
<meta name="geo.position" content="45.4765;-75.7013" />
<meta name="ICBM" content="45.4765, -75.7013" />
<meta property="og:image:alt" content="Krong Thai Restaurant — Authentic Thai, Vietnamese & Cambodian Cuisine" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Krong Thai Restaurant",
  "image": `${base}/images/hero.jpg`,
  "url": "https://restaurantkrongthai.com",
  "telephone": "+18192435000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "205 Rue Bellehumeur",
    "addressLocality": "Gatineau",
    "addressRegion": "QC",
    "postalCode": "J8T 8H3",
    "addressCountry": "CA"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 45.4765, "longitude": -75.7013 },
  "servesCuisine": ["Thai", "Vietnamese", "Cambodian"],
  "priceRange": "$$",
  "acceptsReservations": "True",
  "paymentAccepted": "Cash, Credit Card, Debit Card",
  "currenciesAccepted": "CAD",
  "sameAs": [
    business.social.facebook,
    business.social.instagram,
    business.social.yelp,
    business.delivery.ubereats,
    business.delivery.doordash,
    business.delivery.skip
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": `${base}/${locale}/menu/`,
    "name": locale === "fr" ? "Menu du restaurant" : "Restaurant Menu"
  },
  "potentialAction": {
    "@type": "OrderAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": business.orderingUrl,
      "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
    },
    "deliveryMethod": ["http://purl.org/goodrelations/v1#DeliveryModePickUp"]
  },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.2", "reviewCount": "220" },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "15:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Wednesday", "Thursday"], "opens": "11:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Friday", "Saturday"], "opens": "11:00", "closes": "22:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "15:00", "closes": "21:00" }
  ]
})} />
{pageName && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": locale === "fr" ? "Accueil" : "Home", "item": `${base}/${locale}/` },
      { "@type": "ListItem", "position": 2, "name": pageName, "item": canonical }
    ]
  })} />
)}
