---
import { business } from "../data/business";
import { type Locale, t, getAlternateLocale, localizedPath } from "../i18n/utils";

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = "" } = Astro.props;
const i = t(locale);
const altLocale = getAlternateLocale(locale);
const altHref = localizedPath(altLocale, currentPath);
---

<header class="fixed top-0 left-0 right-0 z-50" id="site-header">
  <div class="mx-auto max-w-7xl px-4 pt-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between rounded-2xl border border-white/[0.06] bg-black/60 px-5 py-3 backdrop-blur-2xl sm:px-6" style="height: 64px;">
      <!-- Logo -->
      <a href={localizedPath(locale, "")} class="group flex items-center gap-2.5">
        <img src="/images/logo.svg" alt="Krong Thai" width="32" height="32" class="h-8 w-8 transition-transform duration-300 group-hover:rotate-12" />
        <span class="text-lg font-bold tracking-tight text-white font-display">Krong Thai</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden items-center gap-0.5 lg:flex">
        {[
          { label: i.nav.home, href: localizedPath(locale, ""), active: !currentPath },
          { label: i.nav.menu, href: localizedPath(locale, "menu"), active: currentPath === "menu" },
          { label: i.nav.about, href: localizedPath(locale, "about"), active: currentPath === "about" },
          { label: i.nav.catering, href: localizedPath(locale, "catering"), active: currentPath === "catering" },
          { label: i.nav.specials, href: localizedPath(locale, "specials"), active: currentPath === "specials" },
          { label: i.nav.contact, href: localizedPath(locale, "contact"), active: currentPath === "contact" },
        ].map((link) => (
          <a
            href={link.href}
            class:list={[
              "relative rounded-full px-4 py-2 text-sm font-medium transition-all duration-300",
              link.active
                ? "bg-white/10 text-golden-light"
                : "text-white/60 hover:text-white hover:bg-white/[0.05]",
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="hidden items-center gap-3 lg:flex">
        <a href={altHref} class="rounded-full px-3 py-2 text-xs font-bold uppercase tracking-widest text-white/40 transition-colors hover:text-golden-light">
          {i.nav.switchLang}
        </a>
        <a href={`tel:${business.phone}`} class="flex items-center gap-2 rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-white/70 transition-all hover:border-golden/30 hover:text-golden-light">
          {i.nav.callUs}
        </a>
        <a
          href={business.orderingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full bg-krong-red px-6 py-2.5 text-sm font-bold text-white shadow-red transition-all duration-300 hover:shadow-xl hover:brightness-110 active:scale-[0.97]"
        >
          {i.nav.orderNow}
        </a>
      </div>

      <!-- Mobile -->
      <button id="mobile-menu-btn" class="flex size-10 items-center justify-center rounded-full bg-white/10 text-white lg:hidden" aria-label="Toggle menu" aria-expanded="false">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden px-4 pt-2 lg:hidden">
    <div class="rounded-2xl border border-white/[0.06] bg-black/80 p-5 backdrop-blur-2xl">
      <div class="space-y-1">
        {[
          { label: i.nav.home, href: localizedPath(locale, "") },
          { label: i.nav.menu, href: localizedPath(locale, "menu") },
          { label: i.nav.about, href: localizedPath(locale, "about") },
          { label: i.nav.catering, href: localizedPath(locale, "catering") },
          { label: i.nav.specials, href: localizedPath(locale, "specials") },
          { label: i.nav.contact, href: localizedPath(locale, "contact") },
        ].map((link) => (
          <a href={link.href} class="block rounded-xl px-4 py-3 font-medium text-white/80 transition-colors hover:bg-white/[0.05] hover:text-golden-light">
            {link.label}
          </a>
        ))}
      </div>
      <div class="mt-4 space-y-2.5 border-t border-white/10 pt-4">
        <a href={business.orderingUrl} target="_blank" rel="noopener noreferrer" class="flex w-full items-center justify-center rounded-xl bg-krong-red py-3.5 font-bold text-white shadow-red">
          {i.nav.orderNow}
        </a>
        <a href={`tel:${business.phone}`} class="flex w-full items-center justify-center rounded-xl border border-white/10 py-3.5 font-medium text-white/70">
          {business.phoneDisplay}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
