---
interface Props {
  headline: string;
  subheadline: string;
  imageSrc: string;
  imageAlt: string;
  badgeText?: string;
  badgeSubtext?: string;
}

const { headline, subheadline, imageSrc, imageAlt, badgeText, badgeSubtext } = Astro.props;
---

<section class="relative min-h-[100svh] overflow-hidden bg-night-950">
  <!-- Background image with parallax feel -->
  <picture>
    <source srcset={imageSrc.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
    <img src={imageSrc} alt={imageAlt} class="absolute inset-0 h-full w-full object-cover scale-105" fetchpriority="high" loading="eager" width="1600" height="900" />
  </picture>

  <!-- Multi-layer overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-night-950"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-transparent to-black/30"></div>

  <!-- Ambient glow -->
  <div class="absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-krong-red/8 blur-[150px]"></div>

  <div class="relative z-10 flex min-h-[100svh] items-center px-5 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl text-center">
      {badgeText && (
        <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-golden/20 bg-golden/[0.07] px-6 py-2.5 backdrop-blur-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-golden animate-pulse"></span>
          <span class="text-sm font-semibold tracking-wide text-golden-light">{badgeText}</span>
        </div>
      )}

      {!badgeText && (
        <div class="mb-10">
          <img src="/images/logo.svg" alt="Krong Thai" width="120" height="120" class="mx-auto h-24 w-24 drop-shadow-[0_0_40px_rgba(212,175,55,0.3)] sm:h-28 sm:w-28 md:h-32 md:w-32" />
        </div>
      )}

      <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-tight text-white sm:text-6xl md:text-7xl lg:text-8xl">
        <Fragment set:html={headline.replace(/&/, '<span class="text-gradient-gold">&amp;</span>')} />
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-base font-medium tracking-wide text-white/50 sm:text-lg">
        {subheadline}
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <slot />
      </div>

      {badgeSubtext && (
        <p class="mt-10 text-xs font-medium uppercase tracking-[0.2em] text-white/25">{badgeSubtext}</p>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] font-semibold uppercase tracking-[0.25em] text-white/20">Scroll</span>
      <div class="h-10 w-[1px] bg-gradient-to-b from-white/30 to-transparent"></div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-night-950 to-transparent"></div>
</section>
