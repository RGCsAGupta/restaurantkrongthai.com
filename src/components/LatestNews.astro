---
import { type Locale, t } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const base = "https://restaurantkrongthai.com";
---

<section class="reveal border-t border-white/[0.06] px-5 py-16 lg:px-8" aria-labelledby="news-heading">
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-golden/70">{i.news.label}</p>
        <h2 id="news-heading" class="mt-2 font-display text-2xl font-bold text-white sm:text-3xl">{i.news.title}</h2>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      {i.news.items.map((item) => {
        const pubDate = new Date(item.date);
        const displayDate = pubDate.toLocaleDateString(locale === 'fr' ? 'fr-CA' : 'en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
        return (
          <article class="rounded-2xl border border-white/[0.06] bg-night-800/40 p-6 transition-colors hover:border-golden/20" itemscope itemtype="https://schema.org/Article">
            <time datetime={item.date} itemprop="datePublished" class="text-xs font-semibold text-golden/60">{displayDate}</time>
            <h3 itemprop="headline" class="mt-2 font-display text-base font-bold text-white">{item.title}</h3>
            <p itemprop="description" class="mt-2 text-sm leading-relaxed text-white/60">{item.summary}</p>
            <meta itemprop="publisher" content="Restaurant Krong Thai" />
            <meta itemprop="url" content={`${base}/${locale}/`} />
          </article>
        );
      })}
    </div>
  </div>
</section>
