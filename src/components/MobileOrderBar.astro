---
import { business } from "../data/business";
import { type Locale, t } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
---

<!-- Sticky bottom bar: mobile only, hidden until user scrolls past hero -->
<div id="mobile-order-bar" class="fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-300 lg:hidden">
  <div class="border-t border-white/[0.08] bg-night-950/95 px-4 py-3 backdrop-blur-xl">
    <div class="flex items-center justify-between gap-3">
      <a href={`tel:${business.phone}`} class="flex items-center gap-2 rounded-full border border-white/10 px-4 py-2.5 text-sm font-medium text-white/70 transition-colors hover:border-golden/30 hover:text-golden-light">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {i.nav.callUs}
      </a>
      <a
        href={business.orderingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 rounded-full bg-krong-red px-6 py-2.5 text-center text-sm font-bold text-white shadow-red transition-all duration-300 hover:brightness-110 active:scale-[0.97]"
      >
        {i.nav.orderNow}
      </a>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById("mobile-order-bar");
  if (bar) {
    let shown = false;
    const observer = new IntersectionObserver(
      ([entry]) => {
        const shouldShow = !entry.isIntersecting;
        if (shouldShow !== shown) {
          shown = shouldShow;
          bar.classList.toggle("translate-y-full", !shown);
          bar.classList.toggle("translate-y-0", shown);
        }
      },
      { threshold: 0 }
    );
    // Observe the hero section (first child of main)
    const hero = document.querySelector("main > :first-child");
    if (hero) observer.observe(hero);
  }
</script>
