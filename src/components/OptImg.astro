---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  width?: number;
  height?: number;
}

const { src, alt, class: className, loading = "lazy", fetchpriority, width, height } = Astro.props;

const webpSrc = src.replace(/\.(jpg|jpeg|png)$/i, ".webp");
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img src={src} alt={alt} class={className} loading={loading} fetchpriority={fetchpriority} width={width} height={height} />
</picture>
