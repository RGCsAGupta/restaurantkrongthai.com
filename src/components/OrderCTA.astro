---
import { business } from "../data/business";
import { type Locale, t } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
---

<section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
  <div class="divider-gold mx-auto mb-24 max-w-xs"></div>

  <!-- Background glow -->
  <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[400px] w-[600px] rounded-full bg-krong-red/[0.06] blur-[150px]"></div>

  <div class="reveal relative mx-auto max-w-3xl text-center">
    <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.orderCta.label}</span>
    <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
      {i.orderCta.title}
    </h2>
    <p class="mt-4 text-lg text-white/60">{i.orderCta.subtitle}</p>

    <a
      href={business.orderingUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10 inline-flex items-center gap-3 rounded-full bg-krong-red px-12 py-5 text-xl font-bold text-white shadow-red transition-all duration-300 hover:shadow-xl hover:brightness-110 active:scale-[0.97] pulse-cta"
    >
      {i.orderCta.primary}
    </a>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/50">{i.orderCta.orVia}</span>
      {[
        { name: i.orderCta.ubereats, href: business.delivery.ubereats },
        { name: i.orderCta.doordash, href: business.delivery.doordash },
        { name: i.orderCta.skip, href: business.delivery.skip },
      ].map((d) => (
        <a
          href={d.href}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium text-white/65 transition-all duration-300 hover:border-golden/30 hover:text-golden-light"
        >
          {d.name}
        </a>
      ))}
    </div>
  </div>
</section>
