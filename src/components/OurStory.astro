---
import { type Locale, t, localizedPath } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
---

<section class="reveal relative overflow-hidden border-t border-white/[0.06] px-5 py-24 lg:px-8 lg:py-32">
  <div class="absolute left-0 top-0 h-[400px] w-[400px] rounded-full bg-krong-red/[0.03] blur-[120px]"></div>

  <div class="mx-auto max-w-7xl">
    <!-- Structured factual intro — data-speakable for AI extraction, Fix [15] -->
    <p data-speakable class="reveal mb-14 mx-auto max-w-3xl text-center text-base leading-relaxed text-white/60">
      {locale === "fr"
        ? "Restaurant Krong Thai est un restaurant authentique thaï, vietnamien et cambodgien fondé par Sothea Say en 1999, situé au 205 rue Bellehumeur, Gatineau, Québec J8T 8H3. C'est le seul restaurant cambodgien de la région Ottawa-Gatineau. Le restaurant est ouvert du mardi au dimanche pour manger sur place, pour emporter et en livraison via UberEats, DoorDash et SkipTheDishes. Apportez votre vin — sans frais de bouchon. Stationnement gratuit sur place."
        : "Restaurant Krong Thai is an authentic Thai, Vietnamese, and Cambodian restaurant founded by Sothea Say in 1999, located at 205 Bellehumeur Street, Gatineau, Quebec J8T 8H3. It is the only Cambodian restaurant in the Ottawa-Gatineau region. Open Tuesday to Sunday for dine-in, takeout, and delivery via UberEats, DoorDash, and SkipTheDishes. BYOB with no corkage fee. Free on-site parking."}
    </p>

    <div class="grid gap-16 lg:grid-cols-2 lg:items-start">

      <!-- Family Story -->
      <div class="reveal">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.about.sinceLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.about.storyTitle}</h2>
        <p class="mt-6 text-base leading-relaxed text-white/65">{i.about.storyText}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-2 rounded-full border border-krong-red/20 bg-krong-red/10 px-4 py-2 text-xs font-bold text-krong-red-glow">
            👨‍🍳 {i.about.familyBadge}
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-golden/20 bg-golden/10 px-4 py-2 text-xs font-bold text-golden">
            🇰🇭 {i.about.cambodianBadge}
          </span>
        </div>
        <div class="mt-8">
          <a
            href={localizedPath(locale, "about")}
            class="inline-flex items-center gap-2 text-sm font-semibold text-golden transition-colors hover:text-golden-light"
          >
            {locale === "fr" ? "En savoir plus sur notre histoire" : "Learn more about our story"}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <!-- Cambodian Heritage -->
      <div class="reveal reveal-delay-1 rounded-3xl border border-white/[0.06] bg-night-800/60 p-8">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden/70">{i.about.heritageLabel}</span>
        <h3 class="mt-3 font-display text-2xl font-bold text-white">{i.about.cambodianTitle}</h3>
        <p class="mt-4 text-sm leading-relaxed text-white/65">{i.about.cambodianText}</p>

        <!-- Key facts as structured sentences for AI extraction -->
        <dl class="mt-6 space-y-3 border-t border-white/[0.06] pt-6">
          <div class="flex items-start gap-3">
            <dt class="sr-only">{locale === "fr" ? "Fondé en" : "Founded"}</dt>
            <span class="mt-0.5 flex-shrink-0 text-golden" aria-hidden="true">✦</span>
            <dd class="text-sm text-white/60">{i.about.whyRecipes}</dd>
          </div>
          <div class="flex items-start gap-3">
            <dt class="sr-only">{locale === "fr" ? "Épices" : "Spices"}</dt>
            <span class="mt-0.5 flex-shrink-0 text-golden" aria-hidden="true">✦</span>
            <dd class="text-sm text-white/60">{i.about.whySpices}</dd>
          </div>
          <div class="flex items-start gap-3">
            <dt class="sr-only">{locale === "fr" ? "Unique" : "Unique"}</dt>
            <span class="mt-0.5 flex-shrink-0 text-golden" aria-hidden="true">✦</span>
            <dd class="text-sm text-white/60">{i.about.whyOnly}</dd>
          </div>
        </dl>
      </div>

    </div>
  </div>
</section>
