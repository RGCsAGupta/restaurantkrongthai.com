---
import type { Locale } from "../i18n/utils";
import { t, localizedPath } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<div
  id="promo-banner"
  class="fixed top-0 left-0 right-0 z-[60] hidden border-b border-golden/15 bg-gradient-to-r from-golden/10 via-golden/[0.06] to-golden/10 backdrop-blur-sm"
  role="banner"
  aria-label={i.promo.ariaLabel}
>
  <div class="mx-auto flex max-w-7xl items-center justify-center gap-x-3 px-4 py-2 sm:px-6">
    <a
      href={localizedPath(locale, "specials")}
      class="flex min-w-0 items-center gap-2 sm:gap-3"
    >
      <span class="shrink-0 rounded-full bg-krong-red px-2.5 py-0.5 text-[11px] font-bold text-white">{i.promo.badge}</span>
      <span class="truncate text-xs font-medium text-white/75 sm:text-sm">{i.promo.text}</span>
      <span class="shrink-0 text-[11px] font-bold text-golden sm:hidden">&rarr;</span>
      <span class="hidden shrink-0 rounded-full border border-golden/30 bg-golden/10 px-3 py-1 text-[11px] font-bold text-golden transition-colors hover:bg-golden/20 hover:text-golden-light sm:inline-block">
        {i.promo.cta} &rarr;
      </span>
    </a>
    <button
      id="promo-dismiss"
      type="button"
      class="shrink-0 rounded-full p-1.5 text-white/40 transition-colors hover:bg-white/[0.06] hover:text-white/60"
      aria-label={i.promo.dismiss}
    >
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById("promo-banner");
  const header = document.getElementById("site-header");
  const dismiss = document.getElementById("promo-dismiss");

  function showBanner() {
    if (!banner || !header) return;
    banner.classList.remove("hidden");
    const h = banner.offsetHeight;
    header.style.top = `${h}px`;
    document.body.style.paddingTop = `${h}px`;
  }

  function hideBanner() {
    if (!banner || !header) return;
    banner.classList.add("hidden");
    header.style.top = "0";
    document.body.style.paddingTop = "0";
    localStorage.setItem("promo-dismissed", String(Date.now()));
  }

  if (banner) {
    const dismissed = localStorage.getItem("promo-dismissed");
    if (!dismissed || Date.now() - Number(dismissed) > 86400000) {
      showBanner();
    }
    dismiss?.addEventListener("click", hideBanner);
  }
</script>
