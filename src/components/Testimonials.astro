---
import { t } from "../i18n/utils";
import { business } from "../data/business";

interface Props { locale: "en" | "fr"; }
const { locale } = Astro.props;
const i = t(locale);
const reviewUrl = `https://search.google.com/local/writereview?placeid=${business.googlePlaceId}`;
---

<section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
  <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
  <div class="absolute right-0 top-0 h-[400px] w-[400px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-16 text-center">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.testimonials.label}</span>
      <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.testimonials.title}</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {i.testimonials.reviews.map((review, idx) => (
        <div class={`reveal reveal-delay-${idx + 1} rounded-3xl border border-white/[0.06] bg-night-800/60 p-8`}>
          <div class="mb-4 flex gap-0.5">
            {Array.from({ length: 5 }).map((_, starIdx) => (
              <svg class={`h-4 w-4 ${starIdx < review.rating ? 'text-golden' : 'text-white/50'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-sm leading-relaxed text-white/65">"{review.text}"</p>
          <p class="mt-4 text-xs font-bold text-white/65">— {review.name}</p>
        </div>
      ))}
    </div>
    <div class="reveal mt-10 text-center">
      <a href={reviewUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-golden/30 bg-golden/10 px-6 py-3 text-sm font-bold text-golden transition-all hover:bg-golden/20 hover:text-golden-light">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        {i.testimonials.cta}
      </a>
    </div>
  </div>
</section>
