---
import { type Locale, t } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);

const props = [
  { icon: "👨‍🍳", title: i.valueProps.familyTitle, desc: i.valueProps.familyDesc, gradient: "from-krong-red/20 to-krong-red/5" },
  { icon: "🇰🇭", title: i.valueProps.cambodianTitle, desc: i.valueProps.cambodianDesc, gradient: "from-golden/20 to-golden/5" },
  { icon: "🍷", title: i.valueProps.byobTitle, desc: i.valueProps.byobDesc, gradient: "from-jade/20 to-jade/5" },
];
---

<section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
  <!-- Background ambient -->
  <div class="absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-golden/[0.03] blur-[120px]"></div>

  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-16 text-center">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.valueProps.label}</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        {i.valueProps.headline}
        <span class="text-gradient-gold">2008</span>
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {props.map((p, idx) => (
        <div class={`reveal reveal-delay-${idx + 1} group relative overflow-hidden rounded-3xl border border-white/[0.06] bg-night-800/80 p-8 transition-all duration-500 hover:border-white/[0.12] hover:bg-night-700/80`}>
          <div class={`absolute -right-12 -top-12 h-32 w-32 rounded-full bg-gradient-to-br ${p.gradient} blur-2xl opacity-0 transition-opacity duration-500 group-hover:opacity-100`}></div>
          <div class="relative">
            <div class="mb-6 text-4xl">{p.icon}</div>
            <h3 class="mb-3 font-display text-xl font-bold text-white">{p.title}</h3>
            <p class="text-sm leading-relaxed text-white/65">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
