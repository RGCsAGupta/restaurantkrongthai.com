---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="404 — Page Not Found"
  description="The page you're looking for doesn't exist or has been moved."
  locale="en"
  currentPath=""
>
  <section class="flex min-h-[60vh] items-center justify-center px-5 py-20">
    <div class="reveal text-center">
      <div class="mb-8 font-display text-[8rem] font-bold leading-none tracking-tight text-gradient-gold sm:text-[10rem]">
        404
      </div>
      <h1 id="nf-title" class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Page Not Found
      </h1>
      <p id="nf-message" class="mx-auto mt-4 max-w-md text-lg text-white/40">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="mt-8">
        <a id="nf-back" href="/en/" class="inline-flex items-center justify-center rounded-full font-bold transition-all duration-300 bg-krong-red text-white shadow-red hover:shadow-xl hover:brightness-110 active:scale-[0.97] pulse-cta px-7 py-3 text-sm">
          Back to Home
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>

<script>
  if (window.location.pathname.startsWith("/fr")) {
    const title = document.getElementById("nf-title");
    const message = document.getElementById("nf-message");
    const back = document.getElementById("nf-back");
    if (title) title.textContent = "Page introuvable";
    if (message) message.textContent = "La page que vous cherchez n'existe pas ou a été déplacée.";
    if (back) {
      back.textContent = "Retour à l'accueil";
      back.setAttribute("href", "/fr/");
    }
    document.title = "404 — Page introuvable";
  }
</script>
