---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import { t, getLocaleFromUrl, localizedPath } from "../i18n/utils";

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
---

<MarketingLayout
  title={`404 — ${i.notFound.title}`}
  description={i.notFound.message}
  locale={locale}
  currentPath=""
>
  <section class="flex min-h-[60vh] items-center justify-center px-5 py-20">
    <div class="reveal text-center">
      <div class="mb-8 font-display text-[8rem] font-bold leading-none tracking-tight text-gradient-gold sm:text-[10rem]">
        404
      </div>
      <h1 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {i.notFound.title}
      </h1>
      <p class="mx-auto mt-4 max-w-md text-lg text-white/40">
        {i.notFound.message}
      </p>
      <div class="mt-8">
        <CTAButton href={localizedPath(locale, "")} variant="primary">
          {i.notFound.back}
        </CTAButton>
      </div>
    </div>
  </section>
</MarketingLayout>
