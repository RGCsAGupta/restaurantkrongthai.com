---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";

const locale = "en";
const i = t(locale);

const timeline = [
  { year: "2008", text: i.about.timeline2008 },
  { year: "2015", text: i.about.timeline2015 },
  { year: "2024", text: i.about.timeline2024 },
];
---

<MarketingLayout title={i.meta.aboutTitle} description={i.meta.aboutDesc} locale={locale} canonicalPath="about" currentPath="about">
  <HeroSection headline={i.about.heroTitle} subheadline={i.about.heroSubtitle} imageSrc="/promo/images/chicken-royal-nest.jpg" imageAlt="Krong Thai Restaurant kitchen" />

  <!-- Story -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="absolute left-0 top-0 h-[400px] w-[400px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-5xl">
      <div class="reveal grid items-center gap-12 md:grid-cols-2">
        <div class="text-center md:text-left">
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Since 2008</span>
          <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl lg:text-5xl">{i.about.storyTitle}</h2>
          <p class="mt-6 max-w-2xl text-base leading-relaxed text-white/40">{i.about.storyText}</p>
        </div>
        <div class="relative">
          <div class="overflow-hidden rounded-3xl border border-white/[0.06]">
            <img src="/promo/images/chef-cooking.jpg" alt="Our chef" class="aspect-[3/4] w-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-4 -right-4 rounded-2xl border border-golden/20 bg-black/80 px-5 py-3 backdrop-blur-md">
            <span class="text-sm font-bold text-golden-light">👨‍🍳 Family recipes since 2008</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cambodian Heritage -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="absolute right-0 bottom-0 h-[400px] w-[400px] rounded-full bg-krong-red/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-5xl">
      <div class="reveal grid items-center gap-12 md:grid-cols-2">
        <div>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-krong-red-glow">Heritage</span>
          <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.about.cambodianTitle}</h2>
          <p class="mt-6 text-base leading-relaxed text-white/40">{i.about.cambodianText}</p>
        </div>
        <div class="relative">
          <div class="overflow-hidden rounded-3xl border border-white/[0.06]">
            <img src="/promo/images/phnom-penh-soup.jpg" alt="Phnom Penh Soup" class="aspect-[4/3] w-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-4 -left-4 rounded-2xl border border-golden/20 bg-black/80 px-5 py-3 backdrop-blur-md">
            <span class="text-sm font-bold text-golden-light">🇰🇭 Only Cambodian in the region</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-3xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Journey</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.about.timelineTitle}</h2>
      </div>
      <div class="relative space-y-12">
        <div class="absolute left-6 top-0 bottom-0 w-px bg-gradient-to-b from-golden/30 via-golden/10 to-transparent md:left-1/2"></div>
        {timeline.map((item, idx) => (
          <div class={`reveal reveal-delay-${idx + 1} relative flex items-start gap-6 md:gap-12 ${idx % 2 === 0 ? '' : 'md:flex-row-reverse'}`}>
            <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-golden/30 bg-night-800 text-sm font-bold text-golden-light">
              {item.year.slice(2)}
            </div>
            <div class="rounded-2xl border border-white/[0.06] bg-night-800/60 p-6 md:max-w-sm">
              <div class="text-sm font-bold text-golden">{item.year}</div>
              <p class="mt-2 text-sm leading-relaxed text-white/40">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Experience -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-5xl">
      <div class="reveal grid items-center gap-12 md:grid-cols-2">
        <div class="relative order-2 md:order-1">
          <div class="overflow-hidden rounded-3xl border border-white/[0.06]">
            <img src="/promo/images/restaurant-dining.jpg" alt="Warm restaurant dining atmosphere" class="aspect-[4/3] w-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-4 -left-4 rounded-2xl border border-golden/20 bg-black/80 px-5 py-3 backdrop-blur-md">
            <span class="text-sm font-bold text-golden-light">🍷 BYOB — no corkage fee</span>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Experience</span>
          <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.about.whyTitle}</h2>
          <div class="mt-8 space-y-5">
            {[i.about.whyRecipes, i.about.whySpices, i.about.whyOnly].map((text, idx) => (
              <div class={`reveal reveal-delay-${idx + 1} flex items-start gap-4`}>
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-golden/15 bg-night-800/80 text-lg">{["👨‍🍳", "🌶️", "🇰🇭"][idx]}</div>
                <p class="text-sm leading-relaxed text-white/40">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactStrip locale={locale} />
</MarketingLayout>
