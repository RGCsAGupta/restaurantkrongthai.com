---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "en";
const i = t(locale);
---

<MarketingLayout title={i.meta.accessibilityTitle} description={i.meta.accessibilityDesc} locale={locale} canonicalPath="accessibility" currentPath="accessibility">
  <section class="relative overflow-hidden bg-night-950 px-5 pb-20 pt-32 lg:px-8 lg:pb-28 lg:pt-40">
    <div class="absolute inset-0 bg-gradient-to-b from-night-800/30 to-night-950"></div>
    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <h1 class="font-display text-4xl font-bold text-white sm:text-5xl">{i.accessibilityPage.title}</h1>
      <p class="mx-auto mt-4 max-w-xl text-sm text-white/55">{i.accessibilityPage.lastUpdated}</p>
    </div>
  </section>

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="mx-auto max-w-3xl">
      <div class="reveal space-y-12 text-sm leading-relaxed text-white/50">

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Our Commitment</h2>
          <p>{business.name} is committed to ensuring that our website and our physical restaurant are accessible to everyone, regardless of ability or technology. We believe that all guests deserve an inclusive and welcoming experience, whether ordering online or dining with us.</p>
        </div>

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Website Accessibility</h2>
          <p class="mb-3">We strive to conform to the Web Content Accessibility Guidelines (WCAG) 2.1 Level AA. Our ongoing efforts include:</p>
          <ul class="ml-5 list-disc space-y-2">
            <li>Semantic HTML markup for proper screen reader navigation</li>
            <li>Sufficient color contrast ratios throughout the site</li>
            <li>Keyboard-navigable menus, forms, and interactive elements</li>
            <li>Descriptive alt text for all meaningful images</li>
            <li>Touch targets meeting the minimum 44x44px requirement</li>
            <li>Visible focus indicators for keyboard users</li>
            <li>Reduced-motion support for users who prefer minimal animation</li>
            <li>Skip-to-content link for efficient navigation</li>
          </ul>
        </div>

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Restaurant Accessibility</h2>
          <p class="mb-3">Our physical location at {business.address.street}, {business.address.city} features:</p>
          <ul class="ml-5 list-disc space-y-2">
            <li>Wheelchair-accessible entrance and dining area</li>
            <li>Accessible washroom facilities</li>
            <li>Free on-site parking with accessible spaces</li>
            <li>Accommodating staff trained to assist guests with diverse needs</li>
          </ul>
        </div>

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Assistive Technologies</h2>
          <p>Our website is designed to be compatible with assistive technologies including screen readers (JAWS, NVDA, VoiceOver), voice recognition software, screen magnification tools, and alternative input devices. If you encounter any issues using assistive technology on our site, please let us know.</p>
        </div>

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Known Limitations</h2>
          <p>While we strive for full accessibility, some third-party content (such as embedded maps or delivery platform links) may not be fully accessible. We are working to identify and address any gaps and will update this page as improvements are made.</p>
        </div>

        <div>
          <h2 class="mb-4 font-display text-xl font-bold text-white">Feedback & Contact</h2>
          <p>We welcome your feedback on the accessibility of our website and restaurant. If you experience any barriers or have suggestions for improvement, please contact us:</p>
          <div class="mt-4 rounded-2xl border border-white/[0.06] bg-night-800/60 p-6">
            <p class="font-bold text-white">{business.name}</p>
            <p class="mt-1">{business.address.street}</p>
            <p>{business.address.city}, {business.address.province} {business.address.postal}</p>
            <p class="mt-2">Email: <a href={`mailto:${business.email}`} class="inline-flex min-h-[44px] items-center text-golden transition-colors hover:text-golden-light">{business.email}</a></p>
            <p>Phone: <a href={`tel:${business.phone}`} class="inline-flex min-h-[44px] items-center text-golden transition-colors hover:text-golden-light">{business.phoneDisplay}</a></p>
          </div>
          <p class="mt-4">We aim to respond to accessibility feedback within 5 business days and will make reasonable efforts to address any issues.</p>
        </div>

      </div>
    </div>
  </section>

  <ContactStrip locale={locale} />
</MarketingLayout>
