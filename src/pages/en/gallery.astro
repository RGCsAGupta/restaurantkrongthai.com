---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";

const locale = "en";
const i = t(locale);

const reviews = [
  {
    name: "Andrew M.",
    source: "Google",
    stars: 5,
    text: "This place was great, such a great meal! We ordered the three person table d'hôte and another ordered the Pad Thai. The meal amount was a great amount and the taste was great too. We will be returning!",
  },
  {
    name: "Lynne L.",
    source: "Google",
    stars: 5,
    text: "I love Krong Thai! The staff is very nice and I love the fresh rolls and Bangkok soup. The pad thai is also very good and the Asian vegetable dish with tofu!",
  },
  {
    name: "Curtis W.",
    source: "Yelp",
    stars: 5,
    text: "Best southeast Asian food I've had in a long time. Dining companion had a terrific pad kra pow with enough kick. The cold rolls were among the best I've had.",
  },
  {
    name: "Sébastien R.",
    source: "Google",
    stars: 5,
    text: "The ideal place. Quick and warm service. Tasty meal. The best Thai foods in Gatineau — so delicious, fresh and healthy.",
  },
];

const photos = [
  { src: "/images/bangkok-soup-large.jpg", alt: i.alt.galleryBangkokSoup, span: "col-span-2 row-span-2" },
  { src: "/images/pad-thai.jpg", alt: i.alt.galleryPadThai },
  { src: "/images/imperial-rolls.jpg", alt: i.alt.galleryImperialRolls },
  { src: "/images/green-curry-chicken.jpg", alt: i.alt.galleryGreenCurry },
  { src: "/images/thai-fried-rice.jpg", alt: i.alt.galleryFriedRice },
  { src: "/images/chef-cooking.jpg", alt: i.alt.galleryChef, span: "col-span-2" },
  { src: "/images/pho-beef.jpg", alt: i.alt.galleryPhoBoeuf },
  { src: "/images/crispy-wontons.jpg", alt: i.alt.galleryWontons },
  { src: "/images/restaurant-dining.jpg", alt: i.alt.galleryDining, span: "col-span-2" },
  { src: "/images/chicken-royal-nest.jpg", alt: i.alt.galleryRoyalNest },
  { src: "/images/thai-spices.jpg", alt: i.alt.gallerySpices },
  { src: "/images/catering-spread.jpg", alt: i.alt.galleryCatering, span: "col-span-2" },
  { src: "/images/dumplings-peanut-sauce.jpg", alt: i.alt.galleryDumplings },
  { src: "/images/spring-rolls-fresh.jpg", alt: i.alt.gallerySpringRolls },
];
---

<MarketingLayout title={i.meta.galleryTitle} description={i.meta.galleryDesc} locale={locale} canonicalPath="gallery" currentPath="gallery">
  <HeroSection headline={i.gallery.heroTitle} subheadline={i.gallery.heroSubtitle} imageSrc="/images/appetizer-platter.jpg" imageAlt={i.alt.heroGallery} />

  <!-- Photo Grid -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.gallery.photosLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.gallery.photosTitle}</h2>
      </div>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4" id="photo-grid">
        {photos.map((photo, idx) => (
          <div class={`reveal reveal-delay-${(idx % 4) + 1} group cursor-pointer overflow-hidden rounded-2xl border border-white/[0.06] ${photo.span || ''}`} data-lightbox={idx}>
            <div class="relative h-full overflow-hidden">
              <picture>
                <source srcset={photo.src.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
                <img src={photo.src} alt={photo.alt} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" width="800" height="640" />
              </picture>
              <div class="absolute inset-0 bg-black/0 transition-all duration-300 group-hover:bg-black/30"></div>
              <div class="absolute bottom-3 left-3 translate-y-4 rounded-full bg-black/60 px-3 py-1 text-xs font-medium text-white opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">{photo.alt}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-5xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.gallery.reviewsLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.gallery.testimonialsTitle}</h2>
        <div class="mt-4 flex items-center justify-center gap-3">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, idx) => (
              <svg class:list={["h-5 w-5", idx < 4 ? "text-golden" : "text-golden/25"]} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-lg font-bold text-white">4.2</span>
          <span class="text-sm text-white/55">({i.social.reviewCount} reviews)</span>
        </div>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {reviews.map((review, idx) => (
          <div class={`reveal reveal-delay-${(idx % 4) + 1} rounded-2xl border border-white/[0.06] bg-night-800/60 p-7`}>
            <div class="mb-4 flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class:list={["h-4 w-4", i < review.stars ? "text-golden" : "text-golden/20"]} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed text-white/50 italic">"{review.text}"</p>
            <div class="mt-5 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-golden/10 text-sm font-bold text-golden">{review.name[0]}</div>
                <span class="text-sm font-semibold text-white/70">{review.name}</span>
              </div>
              <span class="text-xs text-white/50">{review.source}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactStrip locale={locale} />

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/95 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button id="lb-close" class="absolute right-4 top-4 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white" aria-label="Close">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <button id="lb-prev" class="absolute left-4 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white" aria-label="Previous">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="lb-next" class="absolute right-4 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white/70 transition-colors hover:bg-white/20 hover:text-white" aria-label="Next">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>
    <img id="lb-img" class="max-h-[85vh] max-w-[90vw] rounded-xl object-contain" alt="" />
    <div id="lb-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 rounded-full bg-black/60 px-5 py-2 text-sm font-medium text-white/80 backdrop-blur-sm"></div>
  </div>

  <script define:vars={{ photos }}>
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lb-img');
    const lbCaption = document.getElementById('lb-caption');
    let current = 0;

    function open(idx) {
      current = idx;
      update();
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function update() {
      lbImg.src = photos[current].src;
      lbImg.alt = photos[current].alt;
      lbCaption.textContent = `${photos[current].alt} — ${current + 1} / ${photos.length}`;
    }

    function next() { current = (current + 1) % photos.length; update(); }
    function prev() { current = (current - 1 + photos.length) % photos.length; update(); }

    document.querySelectorAll('[data-lightbox]').forEach(el => {
      el.addEventListener('click', () => open(parseInt(el.dataset.lightbox)));
    });

    document.getElementById('lb-close').addEventListener('click', close);
    document.getElementById('lb-prev').addEventListener('click', prev);
    document.getElementById('lb-next').addEventListener('click', next);
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') next();
      if (e.key === 'ArrowLeft') prev();
    });

    let touchStartX = 0;
    lb.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { diff > 0 ? next() : prev(); }
    });
  </script>
</MarketingLayout>
