---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";

const locale = "en";
const i = t(locale);

const photos = [
  { src: "/promo/images/bangkok-soup-large.jpg", alt: "Bangkok Soup", span: "col-span-2 row-span-2" },
  { src: "/promo/images/pad-thai.jpg", alt: "Pad Thai" },
  { src: "/promo/images/imperial-rolls.jpg", alt: "Imperial Rolls" },
  { src: "/promo/images/green-curry-chicken.jpg", alt: "Green Curry" },
  { src: "/promo/images/thai-fried-rice.jpg", alt: "Thai Fried Rice" },
  { src: "/promo/images/chicken-royal-nest.jpg", alt: "Royal Nest", span: "col-span-2" },
  { src: "/promo/images/pho-beef.jpg", alt: "Pho Beef" },
  { src: "/promo/images/crispy-wontons.jpg", alt: "Crispy Wontons" },
  { src: "/promo/images/catering-spread.jpg", alt: "Catering Spread", span: "col-span-2" },
  { src: "/promo/images/dumplings-peanut-sauce.jpg", alt: "Dumplings" },
  { src: "/promo/images/spring-rolls-fresh.jpg", alt: "Fresh Spring Rolls" },
];
---

<MarketingLayout title={i.meta.galleryTitle} description={i.meta.galleryDesc} locale={locale} canonicalPath="gallery" currentPath="gallery">
  <HeroSection headline={i.gallery.heroTitle} subheadline={i.gallery.heroSubtitle} imageSrc="/promo/images/appetizer-platter.jpg" imageAlt="Krong Thai food gallery" />

  <!-- Photo Grid -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Photos</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.gallery.photosTitle}</h2>
      </div>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
        {photos.map((photo, idx) => (
          <div class={`reveal reveal-delay-${(idx % 4) + 1} group overflow-hidden rounded-2xl border border-white/[0.06] ${photo.span || ''}`}>
            <div class="relative h-full overflow-hidden">
              <img src={photo.src} alt={photo.alt} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-black/0 transition-all duration-300 group-hover:bg-black/30"></div>
              <div class="absolute bottom-3 left-3 translate-y-4 rounded-full bg-black/60 px-3 py-1 text-xs font-medium text-white opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">{photo.alt}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-4xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Reviews</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.gallery.testimonialsTitle}</h2>
        <div class="mt-4 flex items-center justify-center gap-3">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, idx) => (
              <svg class:list={["h-5 w-5", idx < 4 ? "text-golden" : "text-golden/25"]} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-lg font-bold text-white">4.2</span>
          <span class="text-sm text-white/30">({i.social.reviewCount} reviews)</span>
        </div>
      </div>
    </div>
  </section>

  <ContactStrip locale={locale} />
</MarketingLayout>
