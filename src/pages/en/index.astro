---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import CTAButton from "../../components/CTAButton.astro";
import SocialProof from "../../components/SocialProof.astro";
import ValueProps from "../../components/ValueProps.astro";
import FeaturedDishes from "../../components/FeaturedDishes.astro";
import ComboSpecial from "../../components/ComboSpecial.astro";
import OrderCTA from "../../components/OrderCTA.astro";
import Testimonials from "../../components/Testimonials.astro";
import BYOBSection from "../../components/BYOBSection.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t, localizedPath } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "en";
const i = t(locale);
---

<MarketingLayout
  title={i.meta.homeTitle}
  description={i.meta.homeDesc}
  locale={locale}
>
  <HeroSection
    headline={i.hero.headline}
    subheadline={i.hero.subheadline}
    imageSrc="/images/bangkok-soup-large.jpg"
    imageAlt={i.alt.heroHome}
    badgeText="Only Cambodian Restaurant in the Region"
    badgeSubtext="Gatineau-Ottawa's Exclusive"
  >
    <CTAButton href={business.orderingUrl} variant="primary" size="lg" external>
      <span class="mr-2 text-2xl">🍜</span>
      {i.hero.cta}
    </CTAButton>
    <CTAButton href={`tel:${business.phone}`} variant="outline" size="lg">
      {i.hero.ctaReserve}
    </CTAButton>
    <CTAButton
      href={localizedPath(locale, "catering")}
      variant="outline"
      size="lg"
    >
      {i.hero.ctaSecondary}
    </CTAButton>
  </HeroSection>

  <!-- Entity Summary — citation-ready for AI/search -->
  <section class="px-5 py-12 lg:px-8" data-speakable>
    <div class="mx-auto max-w-3xl">
      <p class="reveal text-center text-sm leading-relaxed text-white/55">
        {i.entitySummary.text}
      </p>
    </div>
  </section>

  <SocialProof locale={locale} />
  <ValueProps locale={locale} />
  <FeaturedDishes locale={locale} />
  <ComboSpecial locale={locale} />
  <BYOBSection locale={locale} />
  <Testimonials locale={locale} />
  <OrderCTA locale={locale} />

  <!-- Homepage FAQ -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-3xl">
      <div class="reveal mb-12 text-center">
        <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{i.homeFaq.title}</h2>
      </div>
      <div class="space-y-4">
        {i.homeFaq.items.map((item, idx) => (
          <details class={`reveal reveal-delay-${(idx % 4) + 1} group rounded-2xl border border-white/[0.06] bg-night-800/40`}>
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-white/70 transition-colors hover:text-white [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <svg class="h-4 w-4 shrink-0 text-white/50 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="border-t border-white/[0.04] px-6 py-4 text-sm leading-relaxed text-white/65">{item.a}</div>
          </details>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={localizedPath(locale, "contact")} class="text-sm font-semibold text-golden transition-colors hover:text-golden-light">View all FAQs &rarr;</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": i.homeFaq.items.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

  <ContactStrip locale={locale} />
</MarketingLayout>
