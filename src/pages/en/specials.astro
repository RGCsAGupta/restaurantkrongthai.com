---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import CTAButton from "../../components/CTAButton.astro";
import OrderCTA from "../../components/OrderCTA.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "en";
const i = t(locale);

const combos = [
  {
    name: i.specials.lunchCombo,
    desc: i.specials.lunchComboDesc,
    price: i.specials.lunchComboPrice,
  },
  {
    name: i.specials.dinnerCombo,
    desc: i.specials.dinnerComboDesc,
    price: i.specials.dinnerComboPrice,
  },
  {
    name: i.specials.familyCombo,
    desc: i.specials.familyComboDesc,
    price: i.specials.familyComboPrice,
  },
];
---

<MarketingLayout
  title={i.meta.specialsTitle}
  description={i.meta.specialsDesc}
  locale={locale}
  canonicalPath="specials"
  currentPath="specials"
>
  <HeroSection
    headline={i.specials.heroTitle}
    subheadline={i.specials.heroSubtitle}
    imageSrc="/promo/images/pad-thai.jpg"
    imageAlt="Krong Thai specials"
  >
    <CTAButton href={business.orderingUrl} variant="primary" size="lg" external>
      {i.specials.cta}
    </CTAButton>
  </HeroSection>

  <!-- Combos -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Deals</span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {i.specials.comboTitle}
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-8">
        {
          combos.map((c, idx) => (
            <div class={`reveal reveal-delay-${idx + 1} rounded-3xl border border-white/[0.06] bg-night-800/60 p-8 text-center transition-all duration-500 hover:border-white/[0.12]`}>
              <h3 class="mb-3 font-display text-xl font-bold text-white">
                {c.name}
              </h3>
              <p class="mb-6 text-sm leading-relaxed text-white/35">{c.desc}</p>
              <div class="mb-6 font-display text-4xl font-bold text-white">
                {c.price}
              </div>
              <CTAButton
                href={business.orderingUrl}
                variant="primary"
                size="sm"
                external
              >
                {i.specials.cta}
              </CTAButton>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <OrderCTA locale={locale} />
  <ContactStrip locale={locale} />
</MarketingLayout>
