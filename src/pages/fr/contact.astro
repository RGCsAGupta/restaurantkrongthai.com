---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "fr";
const i = t(locale);


const inputClass = "w-full rounded-xl border border-white/10 bg-night-700/80 px-4 py-3.5 text-white placeholder-white/50 transition-all focus:border-golden/50 focus:outline-none focus:ring-2 focus:ring-golden/20";
const labelClass = "mb-1.5 block text-sm font-semibold text-white/60";
---

<MarketingLayout title={i.meta.contactTitle} description={i.meta.contactDesc} locale={locale} canonicalPath="contact" currentPath="contact">
  <HeroSection headline={i.contactPage.heroTitle} subheadline={i.contactPage.heroSubtitle} imageSrc="/images/restaurant-interior.jpg" imageAlt={i.alt.heroContact} />

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-6 md:grid-cols-3">
        <div class="reveal reveal-delay-1 rounded-3xl border border-white/[0.06] bg-night-800/60 p-8 text-center">
          <div class="mb-4 text-3xl">📞</div>
          <h3 class="font-display text-lg font-bold text-white">{i.contactPage.phoneTitle}</h3>
          <p class="mt-2 text-sm text-white/60">{i.contactPage.phoneDesc}</p>
          <a href={`tel:${business.phone}`} class="mt-4 inline-block text-lg font-bold text-golden transition-colors hover:text-golden-light">{business.phoneDisplay}</a>
          <a href={`tel:${business.phone}`} class="mt-3 inline-flex items-center justify-center rounded-full bg-krong-red px-6 py-3 text-sm font-bold text-white shadow-red transition-all duration-300 hover:shadow-xl hover:brightness-110 active:scale-[0.97]">{i.contactPage.reserveBtn}</a>
        </div>
        <div class="reveal reveal-delay-2 rounded-3xl border border-white/[0.06] bg-night-800/60 p-8 text-center">
          <div class="mb-4 text-3xl">📍</div>
          <h3 class="font-display text-lg font-bold text-white">{i.contactPage.locationTitle}</h3>
          <p class="mt-2 text-sm text-white/60">{business.address.street}</p>
          <p class="text-sm text-white/60">{business.address.city}, {business.address.province} {business.address.postal}</p>
          <a href={business.directionsUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block text-sm font-bold text-golden transition-colors hover:text-golden-light">{i.contact.directions}</a>
        </div>
        <div class="reveal reveal-delay-3 rounded-3xl border border-white/[0.06] bg-night-800/60 p-8 text-center">
          <div class="mb-4 text-3xl">🕐</div>
          <h3 class="font-display text-lg font-bold text-white">{i.contactPage.hoursTitle}</h3>
          <div class="mt-3 space-y-1">
            {Object.values(i.contact.hoursData).map((line) => (
              <p class="text-xs text-white/60">{line}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-4xl">
      <div class="reveal mb-12 text-center">
        <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{i.contactPage.amenitiesTitle}</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[i.contactPage.byob, i.contactPage.parking, i.contactPage.accessible, i.contactPage.location].map((text, idx) => (
          <div class={`reveal reveal-delay-${idx + 1} flex items-center gap-4 rounded-2xl border border-white/[0.06] bg-night-800/40 px-6 py-4`}>
            <span class="text-xl">{["🍷", "🚗", "♿", "🎭"][idx]}</span>
            <span class="text-sm text-white/50">{text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-3xl">
      <div class="reveal mb-12 text-center">
        <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{i.contactPage.faqTitle}</h2>
      </div>
      <div class="space-y-4">
        {i.contactPage.faq.map((item, idx) => (
          <details class={`reveal reveal-delay-${(idx % 4) + 1} group rounded-2xl border border-white/[0.06] bg-night-800/40`}>
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-white/70 transition-colors hover:text-white [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <svg class="h-4 w-4 shrink-0 text-white/50 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="border-t border-white/[0.04] px-6 py-4 text-sm leading-relaxed text-white/65">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": i.contactPage.faq.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32" id="form">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="absolute right-0 top-0 h-[400px] w-[400px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
    <div class="reveal mx-auto max-w-2xl">
      <div class="mb-10 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.contactPage.messageLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.contactPage.formTitle}</h2>
        <p class="mt-3 text-sm text-white/60">{i.contactPage.formSubtitle}</p>
      </div>
      <form method="POST" action="/api/contact" class="space-y-6 rounded-3xl border border-white/[0.08] bg-night-800/60 p-8 backdrop-blur-sm sm:p-10">
        <input type="hidden" name="locale" value={locale} />
        <div class="absolute opacity-0 top-0 left-0 h-0 w-0 -z-10" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class={labelClass}>{i.contactPage.formName}</label>
            <input type="text" id="name" name="name" required class={inputClass} />
          </div>
          <div>
            <label for="email" class={labelClass}>{i.contactPage.formEmail}</label>
            <input type="email" id="email" name="email" required class={inputClass} />
          </div>
        </div>
        <div>
          <label for="phone" class={labelClass}>{i.contactPage.formPhone}</label>
          <input type="tel" id="phone" name="phone" class={inputClass} />
        </div>
        <div>
          <label for="message" class={labelClass}>{i.contactPage.formMessage}</label>
          <textarea id="message" name="message" rows="4" required class={inputClass}></textarea>
        </div>
        <button type="submit" class="w-full rounded-full bg-krong-red px-6 py-4 text-lg font-bold text-white shadow-red transition-all duration-300 hover:shadow-xl hover:brightness-110 active:scale-[0.98]">
          {i.contactPage.formSubmit}
        </button>
      </form>
    </div>
  </section>

  <ContactStrip locale={locale} />

  <script>
    document.querySelectorAll('form[action^="/api/"]').forEach((form) => {
      const errClass = "mt-1 text-xs text-red-400 hidden";

      form.querySelectorAll("[required], [type='email'], [type='tel']").forEach((field) => {
        const err = document.createElement("div");
        err.className = errClass;
        err.setAttribute("role", "alert");
        field.parentNode?.appendChild(err);
      });

      form.addEventListener("submit", (e) => {
        let valid = true;
        form.querySelectorAll("[role='alert']").forEach((el) => {
          el.classList.add("hidden");
          el.textContent = "";
        });

        const name = form.querySelector<HTMLInputElement>("#name");
        const email = form.querySelector<HTMLInputElement>("#email");
        const message = form.querySelector<HTMLTextAreaElement>("#message");

        if (name && !name.value.trim()) {
          showError(name, "Ce champ est requis.");
          valid = false;
        }

        if (email) {
          if (!email.value.trim()) {
            showError(email, "Ce champ est requis.");
            valid = false;
          } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
            showError(email, "Veuillez entrer une adresse courriel valide.");
            valid = false;
          }
        }

        if (message && message.hasAttribute("required") && message.value.trim().length < 10) {
          showError(message, "Veuillez écrire au moins 10 caractères.");
          valid = false;
        }

        if (!valid) e.preventDefault();
      });

      function showError(field: Element, msg: string) {
        const err = field.parentNode?.querySelector("[role='alert']");
        if (err) {
          err.textContent = msg;
          err.classList.remove("hidden");
        }
      }
    });
  </script>
</MarketingLayout>
