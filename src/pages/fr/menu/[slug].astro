---
import MarketingLayout from "../../../layouts/MarketingLayout.astro";
import OrderCTA from "../../../components/OrderCTA.astro";
import ContactStrip from "../../../components/ContactStrip.astro";
import { t, localizedPath } from "../../../i18n/utils";
import { business } from "../../../data/business";
import { getAllMenuItemSlugs, getDisplayName, getMenuItemSlug, getRelatedItems } from "../../../data/menu-utils";
import { sideDishes } from "../../../data/menu";

export function getStaticPaths() {
  const allItems = getAllMenuItemSlugs();
  return allItems.map(({ enSlug, frSlug, item, category }) => ({
    params: { slug: frSlug },
    props: { item, category, enSlug },
  }));
}

const locale = "fr";
const i = t(locale);
const { item, category, enSlug } = Astro.props;
const { slug } = Astro.params;

const displayName = getDisplayName(item, locale);
const related = getRelatedItems(item, category);
const basePrice = item.price.includes("/") ? item.price.split("/")[0] : item.price;
const isTableDhote = category.id === "table-dhote";

const pageTitle = `${displayName} | ${i.menuItem.pageTitleSuffix}`;
const pageDesc = item.desc
  ? `${item.desc.fr} — ${i.menuItem.metaDescWithDesc.replace("{name}", displayName)}`
  : i.menuItem.metaDescNoDesc.replace("{name}", displayName).replace("{category}", category.name[locale]);

const breadcrumbs = [
  { name: i.menuItem.breadcrumbHome, path: `/${locale}/` },
  { name: i.menuItem.breadcrumbMenu, path: `/${locale}/menu/` },
  { name: displayName, path: `/${locale}/menu/${slug}/` },
];
---

<MarketingLayout
  title={pageTitle}
  description={pageDesc}
  locale={locale}
  canonicalPath={`menu/${slug}`}
  alternatePath={`menu/${enSlug}`}
  breadcrumbs={breadcrumbs}
  ogImage={item.img}
  currentPath="menu"
>
  <!-- JSON-LD MenuItem -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MenuItem",
    "name": displayName,
    ...(item.desc ? { "description": item.desc.fr } : {}),
    ...(item.img ? { "image": `https://restaurantkrongthai.com${item.img}` } : {}),
    "offers": {
      "@type": "Offer",
      "price": basePrice.replace("+", ""),
      "priceCurrency": "CAD",
    },
    "menuAddOn": !isTableDhote ? {
      "@type": "MenuItem",
      "name": "Combo Table d'hôte",
      "description": "Soupe + entrée + riz jasmin + café ou thé + biscuits aux amandes",
      "offers": { "@type": "Offer", "price": "10", "priceCurrency": "CAD" }
    } : undefined,
  })} />

  <article class="px-5 pt-24 pb-12 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-white/60" aria-label={i.menuItem.breadcrumbLabel}>
        <a href={`/${locale}/`} class="transition-colors hover:text-white">{i.menuItem.breadcrumbHome}</a>
        <span class="mx-1 text-white/30" aria-hidden="true">/</span>
        <a href={`/${locale}/menu/`} class="transition-colors hover:text-white">{i.menuItem.breadcrumbMenu}</a>
        <span class="mx-1 text-white/30" aria-hidden="true">/</span>
        <span class="text-white/90">{displayName}</span>
      </nav>

      <!-- Main content grid -->
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
        <!-- Image / Fallback -->
        <div class="reveal">
          {item.img ? (
            <div class="overflow-hidden rounded-2xl border border-white/[0.06]">
              <picture>
                <source srcset={item.img.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
                <img src={item.img} alt={displayName} class="aspect-[4/3] w-full object-cover" width="800" height="600" />
              </picture>
            </div>
          ) : (
            <div class="flex aspect-[4/3] items-center justify-center rounded-2xl border border-white/[0.06] bg-night-800/40">
              <div class="text-center">
                <span class="text-5xl">{category.icon}</span>
                <p class="mt-2 text-xs text-white/30">{i.menuItem.noPhoto}</p>
              </div>
            </div>
          )}
        </div>

        <!-- Details -->
        <div class="reveal flex flex-col justify-center">
          <div class="mb-2 flex flex-wrap items-center gap-2">
            <span class="text-xs text-white/40">{category.icon} {category.name[locale]}</span>
            {item.popular && (
              <span class="rounded-full bg-krong-red/15 px-2.5 py-0.5 text-[10px] font-bold text-krong-red-glow">{i.menuItem.popular}</span>
            )}
            {item.chefSpecial && (
              <span class="rounded-full bg-golden/15 px-2.5 py-0.5 text-[10px] font-bold text-golden">👨‍🍳 {i.menu.chefSpecial}</span>
            )}
          </div>

          <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">{displayName}</h1>

          {item.desc && (
            <p class="mt-3 text-sm leading-relaxed text-white/60">{item.desc[locale]}</p>
          )}

          <!-- Price -->
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-2xl font-bold text-golden">
              {item.price.includes("/")
                ? `${item.price.split("/")[0]} $ / ${item.price.split("/")[1]} $`
                : item.price.startsWith("+") ? `${item.price.replace("+", "+")} $` : `${item.price} $`}
            </span>
            {category.priceNote && (
              <span class="text-xs text-white/35">{category.priceNote[locale]}</span>
            )}
          </div>

          {item.spicy && (
            <div class="mt-4">
              <span class="rounded-full border border-orange-500/25 bg-orange-500/15 px-2.5 py-1 text-[11px] font-medium text-orange-400">🌶️ {i.menuItem.spicy}</span>
            </div>
          )}

          <!-- Order CTA -->
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={business.orderingUrl} class="inline-flex items-center gap-2 rounded-full bg-krong-red px-6 py-3 text-sm font-bold text-white transition-all hover:brightness-110">
              {i.menuItem.orderThis}
            </a>
            <a href={`/${locale}/menu/`} class="inline-flex items-center gap-2 rounded-full border border-white/10 px-6 py-3 text-sm font-medium text-white/60 transition-all hover:border-white/20 hover:text-white/80">
              ← {i.menuItem.backToMenu}
            </a>
          </div>
        </div>
      </div>

      <!-- Table d'Hôte Upsell — Enhanced -->
      {!isTableDhote && (
        <div class="reveal mt-12 overflow-hidden rounded-2xl border-2 border-golden/20 bg-gradient-to-br from-golden/[0.06] via-golden/[0.03] to-transparent">
          <div class="border-l-4 border-golden p-6 sm:p-8">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="flex-1">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-golden/15 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-golden">{i.menuItem.comboBadge}</span>
                  <h2 class="font-display text-lg font-bold text-golden sm:text-xl">{i.menuItem.comboUpgrade}</h2>
                </div>
                <ul class="mt-3 space-y-1.5">
                  <li class="flex items-center gap-2 text-sm text-white/60">
                    <svg class="h-4 w-4 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    {i.menuItem.comboItem1}
                  </li>
                  <li class="flex items-center gap-2 text-sm text-white/60">
                    <svg class="h-4 w-4 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    {i.menuItem.comboItem2}
                  </li>
                  <li class="flex items-center gap-2 text-sm text-white/60">
                    <svg class="h-4 w-4 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    {i.menuItem.comboItem3}
                  </li>
                </ul>
                <div class="mt-5 flex flex-wrap items-center gap-3">
                  <a href={business.orderingUrl} class="inline-flex items-center gap-2 rounded-full bg-krong-red px-5 py-2.5 text-sm font-bold text-white transition-all hover:brightness-110" target="_blank" rel="noopener noreferrer">
                    {i.menuItem.comboOrderCta}
                  </a>
                  <a href={localizedPath(locale, "specials")} class="text-xs font-medium text-golden transition-colors hover:text-golden-light">
                    {i.menuItem.viewAllCombos} &rarr;
                  </a>
                </div>
              </div>
              <span class="rounded-full bg-krong-red/15 px-5 py-2.5 font-display text-2xl font-bold text-krong-red-glow">{i.menuItem.comboPrice}</span>
            </div>
          </div>
        </div>
      )}

      <!-- Customize Your Meal — Side Dishes -->
      {!isTableDhote && (
        <div class="reveal mt-10">
          <h2 class="mb-4 font-display text-lg font-bold text-white">{i.menuItem.customizeTitle}</h2>
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
            {sideDishes.map((side) => (
              <div class="flex items-center justify-between rounded-xl border border-white/[0.06] bg-night-800/30 px-4 py-2.5">
                <span class="text-sm text-white/70">{side.name[locale]}</span>
                <span class="ml-2 shrink-0 font-display text-sm font-bold text-golden">{side.price} $</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Related Dishes -->
      {related.length > 0 && (
        <div class="reveal mt-14">
          <h2 class="mb-6 font-display text-xl font-bold text-white">{i.menuItem.moreFrom} {category.name[locale]}</h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {related.map((rel) => {
              const relSlug = getMenuItemSlug(rel, locale);
              const relName = getDisplayName(rel, locale);
              return (
                <a href={`/${locale}/menu/${relSlug}/`} class="group overflow-hidden rounded-xl border border-white/[0.06] bg-night-800/30 transition-all hover:border-white/[0.12] hover:bg-night-800/50">
                  {rel.img ? (
                    <picture>
                      <source srcset={rel.img.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
                      <img src={rel.img} alt={relName} class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" width="400" height="250" />
                    </picture>
                  ) : (
                    <div class="flex aspect-[16/10] items-center justify-center bg-night-800/40">
                      <span class="text-3xl">{category.icon}</span>
                    </div>
                  )}
                  <div class="p-3">
                    <h3 class="text-sm font-medium text-white/80 transition-colors group-hover:text-golden-light">{relName}</h3>
                    <span class="mt-1 block font-display text-sm font-bold text-white/50">{rel.price} $</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </article>

  <OrderCTA locale={locale} />
  <ContactStrip locale={locale} />
</MarketingLayout>
