---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import CTAButton from "../../components/CTAButton.astro";
import OrderCTA from "../../components/OrderCTA.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "fr";
const i = t(locale);

const month = new Date().getMonth();
const season = month >= 2 && month <= 4 ? "spring" : month >= 5 && month <= 7 ? "summer" : month >= 8 && month <= 10 ? "fall" : "winter";

// Seasonal dish name → detail page slug mapping (FR slugs)
const seasonalDishSlugs: Record<string, Record<string, string>> = {
  winter: { "Soupe Bangkok": "soupe-bangkok", "Cari vert": "cari-vert-gaeng-keow-warn", "Pho": "pho", "Tom Yum Koong": "tom-yum-koong" },
  spring: { "Rouleaux de printemps": "rouleaux-de-printemps-frais", "Salade de mangue": "salade-de-mangue", "Salade cambodgienne": "salade-cambodgienne", "Légumes asiatiques": "legumes-asiatiques-tofu" },
  summer: { "Rouleaux de printemps": "rouleaux-de-printemps-frais", "Pad Thai": "pad-thai", "Panang au tofu": "panang-au-tofu", "Crevettes thaïes": "crevettes-thaies" },
  fall: { "Nid Royal": "nid-royal-nouilles-croustillantes", "Cari rouge": "cari-rouge-pa-nang", "Soupe Phnom Penh": "soupe-phnom-penh", "Soupe Bangkok": "soupe-bangkok" },
};

const seasonalData = {
  winter: { title: i.specials.winterTitle, desc: i.specials.winterDesc, dishes: i.specials.winterDishes, emoji: "🍲", img: "/images/bangkok-soup-large.jpg" },
  spring: { title: i.specials.springTitle, desc: i.specials.springDesc, dishes: i.specials.springDishes, emoji: "🌿", img: "/images/spring-rolls-fresh.jpg" },
  summer: { title: i.specials.summerTitle, desc: i.specials.summerDesc, dishes: i.specials.summerDishes, emoji: "🥗", img: "/images/pad-thai.jpg" },
  fall: { title: i.specials.fallTitle, desc: i.specials.fallDesc, dishes: i.specials.fallDishes, emoji: "🍂", img: "/images/chicken-royal-nest.jpg" },
};
const seasonal = seasonalData[season];
const currentDishSlugs = seasonalDishSlugs[season];

const highlights = [
  { emoji: "🍜", title: i.specials.bestSeller1, desc: i.specials.bestSeller1Desc, img: "/images/bangkok-soup-large.jpg", slug: "soupe-bangkok" },
  { emoji: "🥢", title: i.specials.bestSeller2, desc: i.specials.bestSeller2Desc, img: "/images/pad-thai.jpg", slug: "pad-thai" },
  { emoji: "🥟", title: i.specials.bestSeller3, desc: i.specials.bestSeller3Desc, img: "/images/imperial-rolls.jpg", slug: "rouleaux-imperiaux" },
];

const perks = [
  { emoji: "🍷", text: i.specials.perk1 },
  { emoji: "🚗", text: i.specials.perk2 },
  { emoji: "⏱️", text: i.specials.perk3 },
  { emoji: "🚚", text: i.specials.perk4 },
];

const combos = [
  {
    name: i.specials.combo1,
    desc: i.specials.combo1Desc,
    price: i.specials.combo1Price,
  },
  {
    name: i.specials.combo2,
    desc: i.specials.combo2Desc,
    price: i.specials.combo2Price,
  },
  {
    name: i.specials.combo3,
    desc: i.specials.combo3Desc,
    price: i.specials.combo3Price,
  },
  {
    name: i.specials.combo4,
    desc: i.specials.combo4Desc,
    price: i.specials.combo4Price,
  },
  {
    name: i.specials.combo5,
    desc: i.specials.combo5Desc,
    price: i.specials.combo5Price,
  },
];
---

<MarketingLayout
  title={i.meta.specialsTitle}
  description={i.meta.specialsDesc}
  locale={locale}
  canonicalPath="speciaux"
  currentPath="specials"
  hidePromoBanner
>
  <HeroSection
    headline={i.specials.heroTitle}
    subheadline={i.specials.heroSubtitle}
    imageSrc="/images/pad-thai.jpg"
    imageAlt={i.alt.heroSpecials}
  >
    <CTAButton href={business.orderingUrl} variant="primary" size="lg" external>
      {i.specials.cta}
    </CTAButton>
  </HeroSection>

  <!-- Combos -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.specials.dealsLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {i.specials.comboTitle}
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 md:gap-8">
        {
          combos.map((c, idx) => {
            const isHero = idx === 0;
            const isGroup = idx >= 3;
            return (
              <div class={`reveal reveal-delay-${(idx % 3) + 1} relative rounded-3xl p-8 text-center transition-all duration-500 ${isHero ? 'border-2 border-golden/30 bg-gradient-to-br from-golden/[0.08] via-golden/[0.03] to-transparent sm:col-span-2 lg:col-span-1' : 'border border-white/[0.06] bg-night-800/60 hover:border-white/[0.12]'}`}>
                {isHero && (
                  <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-golden px-4 py-1 text-[10px] font-bold uppercase tracking-wider text-night-950 whitespace-nowrap">{i.specials.mostPopularBadge}</div>
                )}
                {isGroup && (
                  <div class="mb-3 inline-block rounded-full bg-jade/15 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-jade">{i.specials.groupDealBadge}</div>
                )}
                <h3 class="mb-3 font-display text-xl font-bold text-white">
                  {c.name}
                </h3>
                <p class="mb-4 text-sm leading-relaxed text-white/60">{c.desc}</p>
                {isHero && (
                  <ul class="mx-auto mb-4 max-w-xs space-y-1 text-left">
                    <li class="flex items-center gap-2 text-xs text-white/50">
                      <svg class="h-3.5 w-3.5 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {i.specials.comboIncludes1}
                    </li>
                    <li class="flex items-center gap-2 text-xs text-white/50">
                      <svg class="h-3.5 w-3.5 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {i.specials.comboIncludes2}
                    </li>
                    <li class="flex items-center gap-2 text-xs text-white/50">
                      <svg class="h-3.5 w-3.5 shrink-0 text-golden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {i.specials.comboIncludes3}
                    </li>
                  </ul>
                )}
                <div class={`mb-6 font-display text-4xl font-bold ${isHero ? 'text-golden' : 'text-white'}`}>
                  {c.price}
                </div>
                {isHero && (
                  <p class="mb-4 text-[11px] text-white/40">{i.specials.perPersonNote}</p>
                )}
                <CTAButton
                  href={business.orderingUrl}
                  variant="primary"
                  size="sm"
                  external
                >
                  {i.specials.cta}
                </CTAButton>
              </div>
            );
          })
        }
      </div>
      <p class="reveal mt-6 text-center text-sm text-white/50">{i.specials.substitutionNote}</p>
    </div>
  </section>

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.specials.bestSellersLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.specials.pairTitle}</h2>
        <p class="mx-auto mt-3 max-w-lg text-sm text-white/60">{i.specials.pairDesc}</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {highlights.map((item, idx) => (
          <a href={`/${locale}/menu/${item.slug}/`} class={`reveal reveal-delay-${idx + 1} group overflow-hidden rounded-3xl border border-white/[0.06] bg-night-800/60 transition-all duration-500 hover:border-golden/20`}>
            <div class="relative aspect-[4/3] overflow-hidden">
              <picture>
                <source srcset={item.img.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
                <img src={item.img} alt={item.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" width="800" height="600" />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-night-950/80 to-transparent"></div>
              <div class="absolute bottom-4 left-4 text-3xl">{item.emoji}</div>
            </div>
            <div class="p-6">
              <h3 class="font-display text-lg font-bold text-white transition-colors group-hover:text-golden-light">{item.title}</h3>
              <p class="mt-2 text-sm text-white/65">{item.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-3xl">
      <div class="reveal mb-12 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.specials.perksLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.specials.perksTitle}</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {perks.map((perk, idx) => (
          <div class={`reveal reveal-delay-${idx + 1} flex items-center gap-4 rounded-2xl border border-white/[0.06] bg-night-800/40 px-6 py-5`}>
            <span class="text-2xl">{perk.emoji}</span>
            <span class="text-sm font-medium text-white/50">{perk.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Seasonal Highlights -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="mx-auto max-w-5xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">{i.specials.seasonalLabel}</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-white sm:text-4xl">{i.specials.seasonalTitle}</h2>
      </div>
      <div class="reveal rounded-3xl border border-white/[0.06] bg-night-800/60 overflow-hidden md:grid md:grid-cols-2">
        <div class="relative aspect-[4/3] md:aspect-auto overflow-hidden">
          <picture>
            <source srcset={seasonal.img.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
            <img src={seasonal.img} alt={seasonal.title} class="h-full w-full object-cover" loading="lazy" width="800" height="600" />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-night-950/60 to-transparent md:bg-gradient-to-r"></div>
        </div>
        <div class="p-8 sm:p-10 flex flex-col justify-center">
          <div class="text-4xl mb-4">{seasonal.emoji}</div>
          <h3 class="font-display text-2xl font-bold text-white">{seasonal.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">{seasonal.desc}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {seasonal.dishes.split(", ").map((dish) => {
              const dishName = dish.replace(/\s+\d+[\d/ $]*\$$/, "");
              const slug = currentDishSlugs[dishName];
              return slug ? (
                <a href={`/${locale}/menu/${slug}/`} class="rounded-full border border-golden/20 bg-golden/10 px-3 py-1 text-xs font-semibold text-golden transition-colors hover:bg-golden/20 hover:text-golden-light">{dish}</a>
              ) : (
                <span class="rounded-full border border-golden/20 bg-golden/10 px-3 py-1 text-xs font-semibold text-golden">{dish}</span>
              );
            })}
          </div>
          <div class="mt-8">
            <CTAButton href={business.orderingUrl} variant="primary" size="sm" external>
              {i.specials.cta}
            </CTAButton>
          </div>
        </div>
      </div>
    </div>
  </section>

  <OrderCTA locale={locale} />
  <ContactStrip locale={locale} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Table d'hôte — Combos Restaurant Krong Thai",
    "description": "Combos et menus fixes au Restaurant Krong Thai, Gatineau",
    "url": "https://restaurantkrongthai.com/fr/speciaux/",
    "numberOfItems": 5,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "item": { "@type": "MenuItem", "name": "Combo 1 personne — Spécial du midi", "description": "Ajoutez à tout plat principal : choix de soupe, entrée, riz jasmin, café ou thé, biscuits aux amandes", "offers": { "@type": "Offer", "price": "10.00", "priceCurrency": "CAD", "priceValidUntil": "2025-12-31" } } },
      { "@type": "ListItem", "position": 2, "item": { "@type": "MenuItem", "name": "Menu fixe 2 personnes", "offers": { "@type": "Offer", "price": "60.00", "priceCurrency": "CAD" } } },
      { "@type": "ListItem", "position": 3, "item": { "@type": "MenuItem", "name": "Jardin Éternel 2 personnes", "offers": { "@type": "Offer", "price": "60.00", "priceCurrency": "CAD" } } },
      { "@type": "ListItem", "position": 4, "item": { "@type": "MenuItem", "name": "Menu fixe 3 personnes", "offers": { "@type": "Offer", "price": "85.00", "priceCurrency": "CAD" } } },
      { "@type": "ListItem", "position": 5, "item": { "@type": "MenuItem", "name": "Menu fixe 4 personnes", "offers": { "@type": "Offer", "price": "110.00", "priceCurrency": "CAD" } } }
    ]
  })} />
</MarketingLayout>
