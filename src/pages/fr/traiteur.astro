---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import CTAButton from "../../components/CTAButton.astro";
import CateringForm from "../../components/CateringForm.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import { t } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "fr";
const i = t(locale);

const services = [
  { icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>`, title: i.catering.corporate, desc: i.catering.corporateDesc },
  { icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`, title: i.catering.private, desc: i.catering.privateDesc },
  { icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`, title: i.catering.family, desc: i.catering.familyDesc },
];

const menus = [
  { title: i.catering.appetizers, items: i.catering.appetizerItems, price: i.catering.basicPrice, label: i.catering.basicLabel },
  { title: i.catering.mains, items: i.catering.mainItems, price: i.catering.standardPrice, label: i.catering.standardLabel },
  { title: i.catering.premium, items: i.catering.premiumItems, price: i.catering.premiumPrice, label: i.catering.premiumLabel },
];
---

<MarketingLayout
  title={i.meta.cateringTitle}
  description={i.meta.cateringDesc}
  locale={locale}
  canonicalPath="traiteur"
  currentPath="catering"
>
  <HeroSection
    headline={i.catering.heroTitle}
    subheadline={i.catering.heroSubtitle}
    imageSrc="/promo/images/catering-spread.jpg"
    imageAlt="Service traiteur Krong Thai"
  >
    <CTAButton href="#inquiry" variant="primary" size="lg">
      {i.catering.formTitle}
    </CTAButton>
    <CTAButton href={`tel:${business.phone}`} variant="outline" size="lg">
      {i.nav.callUs}
    </CTAButton>
  </HeroSection>

  <!-- Services -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="absolute left-0 top-0 h-[400px] w-[400px] rounded-full bg-golden/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-golden">Services</span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {i.catering.serviceTitle}
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-8">
        {
          services.map((s, idx) => (
            <div class={`reveal reveal-delay-${idx + 1} group rounded-3xl border border-white/[0.06] bg-night-800/80 p-8 text-center transition-all duration-500 hover:border-white/[0.12] hover:bg-night-700/80`}>
              <div class="mx-auto mb-5 inline-flex rounded-2xl bg-golden/10 p-3 text-golden">
                <Fragment set:html={s.icon} />
              </div>
              <h3 class="mb-3 font-display text-xl font-bold text-white">{s.title}</h3>
              <p class="text-sm leading-relaxed text-white/40">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Sample Menus -->
  <section class="relative overflow-hidden px-5 py-24 lg:px-8 lg:py-32">
    <div class="divider-gold mx-auto mb-24 max-w-xs"></div>
    <div class="absolute right-0 bottom-0 h-[400px] w-[400px] rounded-full bg-krong-red/[0.03] blur-[120px]"></div>
    <div class="mx-auto max-w-7xl">
      <div class="reveal mb-16 text-center">
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-krong-red-glow">Menu</span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {i.catering.menuTitle}
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3 md:gap-8">
        {
          menus.map((m, idx) => (
            <div class={`reveal reveal-delay-${idx + 1} rounded-3xl border border-white/[0.06] bg-night-800/60 p-8 transition-all duration-500 hover:border-white/[0.12]`}>
              <div class="mb-5 flex items-center justify-between">
                <h3 class="font-display text-xl font-bold text-white">{m.title}</h3>
                <span class="rounded-full border border-golden/30 bg-golden/10 px-3 py-1 text-xs font-bold uppercase text-golden-light">
                  {m.label}
                </span>
              </div>
              <p class="mb-6 text-sm leading-relaxed text-white/35">{m.items}</p>
              <div class="border-t border-white/[0.06] pt-5">
                <span class="text-xs font-semibold uppercase tracking-wider text-white/20">{i.catering.pricingFrom}</span>
                <span class="ml-1 font-display text-3xl font-bold text-white">{m.price}</span>
                <span class="text-xs text-white/30"> {i.catering.perPerson}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CateringForm locale={locale} />
  <ContactStrip locale={locale} />
</MarketingLayout>
