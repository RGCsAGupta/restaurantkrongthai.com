---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import OrderCTA from "../../components/OrderCTA.astro";
import ContactStrip from "../../components/ContactStrip.astro";
import CTAButton from "../../components/CTAButton.astro";
import { t, localizedPath } from "../../i18n/utils";
import { business } from "../../data/business";

const locale = "fr";
const i = t(locale);

const neighborhoods = [
  { title: i.areas.gatineauTitle, text: i.areas.gatineauText, icon: "📍" },
  { title: i.areas.hullTitle, text: i.areas.hullText, icon: "🚗" },
  { title: i.areas.aylmerTitle, text: i.areas.aylmerText, icon: "🏡" },
  { title: i.areas.ottawaTitle, text: i.areas.ottawaText, icon: "🌉" },
  { title: i.areas.outaouaisTitle, text: i.areas.outaouaisText, icon: "🌲" },
];
---

<MarketingLayout title={i.meta.areasTitle} description={i.meta.areasDesc} locale={locale} canonicalPath="areas" currentPath="areas">
  <HeroSection headline={i.areas.heroTitle} subheadline={i.areas.heroSubtitle} imageSrc="/images/hero.jpg" imageAlt="Restaurant Krong Thai — service à Gatineau, Hull, Aylmer, Ottawa et la région de l'Outaouais" />

  <!-- Quartiers -->
  <section class="px-5 py-24 lg:px-8">
    <div class="mx-auto max-w-5xl space-y-16">
      {neighborhoods.map((area, idx) => (
        <div class="reveal grid items-start gap-8 md:grid-cols-[auto_1fr]">
          <span class="hidden text-4xl md:block">{area.icon}</span>
          <div>
            <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{area.title}</h2>
            <p class="mt-4 max-w-3xl text-base leading-relaxed text-white/65">{area.text}</p>
            {idx === 0 && (
              <div class="mt-6 flex flex-wrap gap-3">
                <CTAButton href={business.orderingUrl} variant="primary" size="md">{i.areas.orderCta}</CTAButton>
                <CTAButton href={localizedPath(locale, "menu")} variant="outline" size="md">{i.areas.menuCta}</CTAButton>
              </div>
            )}
            {idx === 2 && (
              <div class="mt-6">
                <CTAButton href={localizedPath(locale, "catering")} variant="outline" size="md">{i.areas.cateringCta}</CTAButton>
              </div>
            )}
            {idx === 3 && (
              <div class="mt-6">
                <CTAButton href={localizedPath(locale, "catering")} variant="outline" size="md">{i.areas.cateringCta}</CTAButton>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Partenaires de livraison -->
  <section class="border-t border-white/[0.06] px-5 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-2xl font-bold text-white">{i.areas.deliveryTitle}</h2>
      <p class="mt-4 text-base text-white/60">{i.areas.deliveryText}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={business.delivery.ubereats} class="rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium text-white/70 transition-all hover:border-white/20 hover:text-white" target="_blank" rel="noopener noreferrer">UberEats</a>
        <a href={business.delivery.doordash} class="rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium text-white/70 transition-all hover:border-white/20 hover:text-white" target="_blank" rel="noopener noreferrer">DoorDash</a>
        <a href={business.delivery.skip} class="rounded-full border border-white/10 px-5 py-2.5 text-sm font-medium text-white/70 transition-all hover:border-white/20 hover:text-white" target="_blank" rel="noopener noreferrer">SkipTheDishes</a>
      </div>
      <p class="mt-6 text-sm text-golden">{i.areas.byobReminder}</p>
    </div>
  </section>

  <OrderCTA locale={locale} />
  <ContactStrip locale={locale} />
</MarketingLayout>
