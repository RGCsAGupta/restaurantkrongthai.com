{
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "CDN-Cache-Control", "value": "max-age=31536000" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "CDN-Cache-Control", "value": "max-age=31536000" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "CDN-Cache-Control", "value": "max-age=31536000" }
      ]
    },
    {
      "source": "/en/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/fr/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/fr/", "permanent": true },
    { "source": "/review", "destination": "https://search.google.com/local/writereview?placeid=ChIJu476UxUbzkwRSV2u84dWyWk", "permanent": false },
    { "source": "/avis", "destination": "https://search.google.com/local/writereview?placeid=ChIJu476UxUbzkwRSV2u84dWyWk", "permanent": false },
    { "source": "/promo", "destination": "/fr/", "permanent": true },
    { "source": "/promo/", "destination": "/fr/", "permanent": true },
    { "source": "/promo/:path(.*)", "destination": "/:path", "permanent": true }
  ]
}
